# OpenAI-compatible LLM API config.
# Copy this file to .env locally if you want, but never commit the real .env.
LLM_BASE_URL=
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=kimi-k2.6
LLM_TIMEOUT_SECONDS=60
LLM_CLASSIFY_TIMEOUT_SECONDS=45
LLM_FIELD_INFER_TIMEOUT_SECONDS=45
LLM_REVIEW_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.5
LLM_CONFIDENCE_THRESHOLD=0.75
AUTO_SUPPLEMENT_CONFIDENCE_THRESHOLD=0.80
AUTO_TRANSFER_CONFIDENCE_THRESHOLD=0.85
LLM_ENABLE_REVIEW=false

# OpenAI-compatible embedding API config. Fill EMBEDDING_BASE_URL with your bge-m3 service address.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_FALLBACK_DIMENSION=384

# Legal knowledge-base retrieval config.
LEGAL_VECTOR_TOP_K=10
LEGAL_DISPLAY_TOP_K=3
LEGAL_MIN_RELEVANCE_SCORE=0.55
LEGAL_ENABLE_RERANKER=true

# OpenAI-compatible reranker API config. Fill RERANKER_BASE_URL with your bge-reranker-v2-m3 service address.
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=bge-reranker-v2-m3
RERANKER_TIMEOUT_SECONDS=30
